# ================= PRODUCCIÓN — Baby-Confort =================
APP_NAME="Baby-Confort"
APP_ENV=production
APP_DEBUG=false
# Genera la clave con:  php artisan key:generate --show   y pégala aquí:
APP_KEY=
# La URL final de tu tienda (con https):
APP_URL=https://tudominio.com

# --- Base de datos MySQL (te la da Railway/Hostinger) ---
DB_CONNECTION=mysql
DB_HOST=
DB_PORT=3306
DB_DATABASE=
DB_USERNAME=
DB_PASSWORD=

# --- WhatsApp donde llegan los pedidos ---
WHATSAPP_NUMBER=50368601764

# --- Sesión/caché (por defecto está bien) ---
SESSION_DRIVER=database
CACHE_STORE=database
QUEUE_CONNECTION=database
LOG_LEVEL=error
